# --- Login (two shared passwords) ---
# Set any two passwords. Keep secret.
HER_PASSWORD=her-secret-password
HIS_PASSWORD=his-secret-password
# Used to sign the session cookie. Any long random string.
AUTH_SECRET=change-me-to-a-long-random-string

# --- WxPusher (https://wxpusher.zjiecode.com) ---
# Create an app there, scan QR to get UIDs for both of you.
WXPUSHER_APP_TOKEN=
WXPUSHER_UID_HER=
WXPUSHER_UID_HIM=

# --- QWeather (https://dev.qweather.com) ---
# Register, create a project + key. Free tier is enough.
QWEATHER_KEY=
# City LocationID. Find at https://github.com/qwd/LocationList. Default: Beijing.
QWEATHER_LOCATION_ID=101010100
QWEATHER_CITY_NAME=北京

# --- Cron secret (any random string) ---
# Required header (x-cron-secret) to trigger /api/cron/morning-push.
CRON_SECRET=change-me
